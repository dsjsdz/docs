{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "ignoreDeprecations": "6.0",
    "moduleResolution": "Node",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "lib": [
      "WebWorker"
    ]
  }
}